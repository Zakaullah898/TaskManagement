@model IEnumerable<TaskManagement.Application.DTOs.TaskTableDTO>
@{
}
<div class="row  g-3">
    @foreach (var item in Model)
    {
        @if(!item.IsDeleted){
        <div class="col d-flex">
            <div class="card @(item.IsDeleted ? "bg-light opacity-50 pe-none" : "none")" style="width: 15rem;" aria-disabled="@(item.IsDeleted ? true: false)">
                <div class="card-header  @(item.IsDeleted ? "bg-danger" : "bg-primary")">
                    <div class="row">
                        <div class="col-6 text-white ">
                            @if(item.IsDeleted)
                            {
                                <i class="bi bi-trash3-fill"></i>
                            }
                            else{

                              @item.Status
                            }
                            </div>
                        <div class="col-6 text-white text-end">
                            <div class="dropdown ">
                                <i 
                                    class="bi bi-three-dots-vertical"
                                    type="button" 
                                    data-bs-toggle="dropdown"
                                   aria-expanded="true"
                                ></i>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-card">
                                    <li><a class="dropdown-item" href="#">Assign Task</a></li>
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="UpdateTask" asp-route-id="@item.TaskId">Edit</a></li>
                                    <li><button class="dropdown-item" onclick="conformationDelete(@item.TaskId)">Delete</button></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                </div>
                <div class="card-body">
                    <h5 class="card-title">@item.Title</h5>
                    <div class="row">
                        <div class="col-12">

                            <span class="text-secondary">Priority: @item.priority</span>
                        </div>
                        <div class="col-12">
                            <span class="text-secondary">Created At: @item.CreatedAt.ToShortDateString()</span>
                        </div>
                    </div>
                    @* <hr /> *@
                    <div class="border-top">
                    <p class="card-text ">
                        @(item.Description.Length > 20 ? item.Description.Substring(0,20) + "....": item.Description)
                        
                    </p>
                            @if (item.Description.Length > 20)
                            {
                                <a class="btn btn-primary btn-sm" asp-controller="Tasks" asp-action="TaskDetails" asp-route-id="@item.TaskId">
                                    Task View
                                </a>
                            }
                    </div>
   
                    
                </div>
            </div>
        </div>
        }
    }

</div>


