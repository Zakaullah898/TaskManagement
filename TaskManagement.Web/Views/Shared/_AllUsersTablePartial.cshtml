@model IEnumerable<TaskManagement.Application.DTOs.UserDTO>

@* <div class="table-responsive mb-0"> *@
    <table class="table table-bordered table-hover align-middle ">
    <thead class="table-dark sticky-header mt-0">
            <tr>
                <th>User Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Last Login</th>
                <th>Active</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody id="taskTableBody">
            @foreach (var item in Model)
            {
                <tr>
                    <td data-user-name="@item.UserName" class="user-name">@item.UserName</td>
                    <td>@item.Email</td>
                <td class="role"
                    data-roles='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(item.Role))'>

                    @foreach (var role in item.Role!)
                    {
                        <span class="badge bg-info me-1">@role</span>
                    }

                </td>

                <td>@item.LastLogin.ToString("yyyy-MM-dd hh:mm tt")</td>
                <td data-is-active="@item.IsActive" class="is-active">
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center">
                        <a class="btn btn-warning btn-sm me-2 edit-user-btn" data-bs-toggle="modal" data-bs-target="#userModal" data-user-id="@item.Id" id="edit-user">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        <button class="btn btn-danger btn-sm delete-user-btn" data-delete-user-id="@item.Id" id="">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    
@* </div> *@


<!-- Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">

            <div class="modal-header">
                <h5 class="modal-title" id="userModalLabel">User Management</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form id="userForm">

                    <!-- Hidden User ID -->
                    <input type="hidden" id="userId" name="userId">

                    <!-- Name -->
                    <div class="mb-3">
                        <label for="userName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="userName" placeholder="Enter full name" required>
                    </div>

                    <!-- Roles -->
                   <div class="mb-3">
    <label class="form-label">Roles</label>
    <div class="dropdown w-100">
        <button class="btn btn-outline-secondary dropdown-toggle w-100 text-start" type="button" id="rolesDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            Select Roles
        </button>
        <ul class="dropdown-menu w-100 p-2" aria-labelledby="rolesDropdown">
            <li>
                <div class="form-check">
                    <input class="form-check-input role-checkbox" type="checkbox" value="Admin" id="roleAdmin">
                    <label class="form-check-label" for="roleAdmin">Admin</label>
                </div>
            </li>
            <li>
                <div class="form-check">
                    <input class="form-check-input role-checkbox" type="checkbox" value="Manager" id="roleManager">
                    <label class="form-check-label" for="roleManager">Manager</label>
                </div>
            </li>
            <li>
                <div class="form-check">
                    <input class="form-check-input role-checkbox" type="checkbox" value="Employee" id="roleUser">
                    <label class="form-check-label" for="roleUser">Employee</label>
                </div>
            </li>
        </ul>
    </div>
</div>


                    <!-- Activation -->
                    <div class="mb-3">
                        <label class="form-label">Activation</label>
                        <select class="form-select" id="userStatus">
                            <option value="active">Active</option>
                            <option value="inactive">Deactive</option>
                        </select>
                    </div>

                    <!-- New Password with Show/Hide -->
                    <div class="mb-3 newPassword">
                        <label for="newPasswordInput" class="form-label">Reset Password</label>
                        <div class="input-group">
                            <input type="password"
                                   class="form-control"
                                   id="newPasswordInput"
                                   placeholder="Enter new password (leave blank if not resetting)">
                            <button 
                                    class="btn btn-outline-secondary"
                                    type="button"
                                    id="togglePassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <!-- Conform Password with Show/Hide -->
                    <div class="mb-3 ConformPassword">
                        <label for="confirmPasswordInput" class="form-label">Reset Password</label>
                        <div class="input-group">
                            <input type="password"
                                   class="form-control"
                                   id="confirmPasswordInput"
                                   placeholder="Enter new password (leave blank if not resetting)">
                            <button 
                                    class="btn btn-outline-secondary"
                                    type="button"
                                    id="toggleConfromPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                </form>
            </div>

            <div class="modal-footer updating-user-btn-section">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" form="userForm" class="btn btn-primary updating-btn">Updating User</button>
            </div>

        </div>
    </div>
</div>
