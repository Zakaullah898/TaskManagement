@model IEnumerable<TaskManagement.Application.DTOs.TaskTableDTO>

@{
    var currentUser = User.Identity?.Name;
    var isAdminOrManager = User.IsInRole("Admin") || User.IsInRole("Manager");

    var visibleTasks = Model
        .Where(t => !t.IsDeleted &&
               (t.AssignedToUserName == currentUser ||
               (t.AssignedToUserName != null && isAdminOrManager)))
        .ToList();
}

<div class="row g-3">

    @if (!visibleTasks.Any())
    {
        <h2>No tasks assigned yet</h2>
    }
    else
    {
        @foreach (var item in visibleTasks)
        {
            <div class="col d-flex">
                <div class="card @(item.IsDeleted ? "bg-light opacity-50 pe-none" : "")"
                     style="width: 15rem;">

                    <div class="card-header
                                @(item.Status == "Completed" ? "bg-success" :
                                                   item.Status == "InProgress" ? "bg-warning" :
                                                   item.Status == "OnHold" ? "bg-danger" :
                                                   "bg-primary")">

                <div class="row">
                    <div class="col-6 text-white">
                        @item.Status
                    </div>

                            <div class="col-6 text-white text-end">
                                <div class="dropdown">
                                    <i class="bi bi-three-dots-vertical"
                                       type="button"
                                       data-bs-toggle="dropdown"></i>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                @if (isAdminOrManager)
                                        {
                                            <li>
                                                <button type="button"
                                                        class="dropdown-item assign-btn"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#assignTask"
                                                        data-id="@item.TaskId">
                                                    Assign Task
                                                </button>
                                            </li>

                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="Tasks"
                                                   asp-action="UpdateTask"
                                                   asp-route-id="@item.TaskId">
                                                    Edit
                                                </a>
                                            </li>

                                            <li>
                                                <button class="dropdown-item"
                                                        onclick="conformationDelete(@item.TaskId)">
                                                    Delete
                                                </button>
                                            </li>
                                        }
                                        else
                                        {
                                            <li>
                                                <button class="dropdown-item status-btn"
                                                        data-task-id="@item.TaskId"
                                                        data-status="InProgress">
                                                    In Progress
                                                </button>
                                            </li>

                                            <li>
                                                <button class="dropdown-item status-btn"
                                                        data-task-id="@item.TaskId"
                                                        data-status="Completed">
                                                    Completed
                                                </button>
                                            </li>

                                            <li>
                                                <button class="dropdown-item status-btn"
                                                        data-task-id="@item.TaskId"
                                                        data-status="OnHold">
                                                    On Hold
                                                </button>
                                            </li>
                                        }

                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <h5 class="card-title">@item.Title</h5>

                    <p class="text-secondary">
                        Priority: @item.priority
                    </p>

                    <p class="text-secondary">
                        Created At: @item.CreatedAt.ToShortDateString()
                    </p>

                    <p>
                        @(item.Description?.Length > 20
                                            ? item.Description.Substring(0, 20) + "..."
                                            : item.Description)
                </p>

                @if (!string.IsNullOrEmpty(item.AssignedToUserName))
                        {
                            <p class="text-secondary">
                                Assigned To: @item.AssignedToUserName
                            </p>
                        }

                        <a class="btn btn-primary btn-sm"
                           asp-controller="Tasks"
                           asp-action="TaskDetails"
                           asp-route-id="@item.TaskId">
                            Task View
                        </a>
                    </div>
                </div>
            </div>
        }
    }

</div>

<!-- Modal OUTSIDE LOOP -->
<div class="modal fade" id="assignTask">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Assign Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form asp-controller="Tasks" asp-action="AssignTask" method="post">
                    <input type="hidden" name="TaskId" id="taskId" />

                    <div class="mb-3">
                        <label class="form-label">Select User</label>
                        <select class="form-select" name="AssigneeId" required></select>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Close
                        </button>

                        <button type="submit"
                                class="btn btn-primary">
                            Assign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



