@model IEnumerable<TaskManagement.Application.DTOs.TaskTableDTO>





    @* <div class="table-responsive"> *@
<table class="table table-bordered table-hover align-middle ">
    <thead class="table-dark sticky-header mt-0">
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
        <tbody id="taskTableBody">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</td>
                <td>@item.UpdatedAt.ToString("yyyy-MM-dd hh:mm tt")</td>
                    <td>@item.Status</td>
                    <td>
                        @if (!item.IsDeleted)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center">
                            <a class="btn btn-warning btn-sm me-2" asp-controller="Tasks" asp-action="UpdateTask" asp-route-id="@item.TaskId">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <button class="btn btn-danger btn-sm" onclick="conformationDelete(@item.TaskId)">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
        </table>

        
    @* </div> *@

