<nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom box-shadow">
    <div class="container-fluid">

        <!-- Left side -->
        <div class="navbar-brand">
            <h1 class="h3 mb-0 LogoFont">Task Management System</h1>
        </div>

        <!-- Right side -->
        <div class="d-flex align-items-center ms-auto">

            @if (User.Identity!.IsAuthenticated)
            {

                <div class="dropdown ms-auto">

                    

                    <!-- 🔥 ViewComponent here -->
                    @await Component.InvokeAsync("NavbarProfile")
                    <!-- Dropdown Menu (LEFT SIDE) -->
                    <ul class="dropdown-menu dropdown-menu-end text-small shadow">

                        <li>
                            <a class="dropdown-item"
                               asp-controller="UserProfile"
                               asp-action="Profile">Profile</a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="#">Settings</a>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <a class="dropdown-item"
                               asp-controller="Auth"
                               asp-action="Logout">Sign out</a>
                        </li>

                    </ul>
                </div>
            }
            else
            {
                <a class="btn btn-primary"
                   asp-controller="Auth"
                   asp-action="Login">Signin</a>
            }

        </div>

    </div>
</nav>