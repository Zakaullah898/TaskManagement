@model string;

<form asp-action="ResetPassword" method="post">
    <input type="hidden" name="Email" value="@Model" id="user-email"/>
    <!-- New Password -->
    <div class="form-group mb-3 position-relative newPassword">
        <label for="newPassword" class="mb-2">New Password</label>
        <input type="password"
               class="form-control pe-5"  
        placeholder="Enter password"
        id="newPassword" />
        <span class="password-toggle"  style="position:absolute; right:10px; top:72%; transform:translateY(-50%); cursor:pointer;">
            <i id="newPasswordIcon" class="bi bi-eye"></i> <!-- Unique ID -->
        </span>
        <span class="text-danger"></span>
    </div>

    <!-- Confirm Password -->
    <div class="form-group mb-3 position-relative ConformPassword">
        <label for="confirmPassword" class="mb-2">Confirm Password</label>
        <input type="password"
               class="form-control pe-5"
               placeholder="Enter password"
               id="confirmPassword" />
        <span class="password-toggle"  style="position:absolute; right:10px; top:72%; transform:translateY(-50%); cursor:pointer;">
            <i id="confirmPasswordIcon" class="bi bi-eye"></i> <!-- Unique ID -->
        </span>
        <span class="text-danger"></span>
    </div>

    <button type="button" class="btn btn-primary w-100 reset-password-btn">
        Reset Password
    </button>
</form>
