@model TaskManagement.Application.DTOs.TaskTableDTO;
@{
    ViewData["Title"] = "Task Details";
}
<div class="w-100 card border-0 p-4 ">
    <div class="card-header bg-success py-3 bg-gradient">
        <div class="row">
            <div class="col text-center">
                <h4 class="text-white mb-0">Task Details</h4>
            </div>
        </div>
    </div>

    @* Body for creating task  *@
    <div class="card-body border p-4">
        <h2 class="card-title">@Model.Title</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <h5>Status:</h5>
                <p>@Model.Status</p>
            </div>
            <div class="col-md-6 mb-3">
                <h5>Priority:</h5>
                <p>@Model.priority</p>
            </div>
            <div class="col-md-6 mb-3">
                <h5>Created At:</h5>
                <p>@Model.CreatedAt.ToString("f")</p>
            </div>
            <div class="col-md-6 mb-3">
                <h5>Last Updated:</h5>
                <p>@Model.UpdatedAt.ToString("f")</p>
            </div>
            <div class="col-md-6 mb-3">
                <h5>Description:</h5>
                <p>@Model.Description</p>
            </div>
            <div class="col-md-6 mb-3">
                <h5>Manager:</h5>
                <p>@Model.CreatedByUserName</p>
            </div>
        </div>
        <hr />
        <div class="d-flex justify-content-between">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
                <i class="bi bi-arrow-left"></i> Back to Tasks
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("Manager")){

            <div>
                <a class="btn btn-warning me-2" asp-controller="Tasks" asp-action="UpdateTask" asp-route-id="@Model.TaskId">
                    <i class="bi bi-pencil-square"></i> Edit Task
                </a>
                <button class="btn btn-danger" onclick="conformationDelete(@Model.TaskId)">
                    <i class="bi bi-trash3-fill"></i> Delete Task
                </button>
            </div>
            }
         </div>
    </div>
</div>

@section Scripts {
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
                        Swal.fire({
                title: 'Error!',
                text: '@TempData["ErrorMessage"]',
                icon: '@TempData["AlertType"]',
                confirmButtonText: 'OK'
            });
        </script>
    }


}

