@model TaskManagement.Application.DTOs.LoginUserDTO;
@{
    ViewData["Title"] = "Login";
}

<h1 class="text-success text-center">
    Task Management
</h1>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Login">
                        
                        <div class="form-group mb-3 ">
                            <label asp-for="Email" class="control-label"></label>
                            <input type="email"
                                   asp-for="Email"
                                   class="form-control"
                                   placeholder="Email" />
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="EnteredPassword" class="control-label"></label>
                            <input type="password"
                                   asp-for="EnteredPassword"
                                   class="form-control"
                                   placeholder="Password"
                                   />
                        </div>

                        <button class="btn btn-danger">
                            Login
                        </button>
                    </form>
                    <p class="mt-3">
                        Not registered?
                        <a asp-action="Register">
                            Create an
                            account
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["Error"] != null)
    {
        <script>
                        Swal.fire({
                icon: 'AlertType',
                title: 'Wrong Credential',
                text: '@TempData["Error"]',
                timer: 1500,
                showConfirmButton: false // Hides the default "OK" butto
            });
        </script>
    }
}