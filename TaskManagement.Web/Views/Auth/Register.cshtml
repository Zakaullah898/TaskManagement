    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model TaskManagement.Application.DTOs.RegisterUserDTO;
@{
    ViewData["Title"] = "Register";
}

<h1 class="text-success text-center">
    Task Management
</h1>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <form asp-action="Login">
                        <div class="row">

                            <div class="form-group mb-3 col-md-6">
                                <label asp-for="UserName" class="control-label"></label>
                                <input type="text"
                                       asp-for="UserName"
                                       class="form-control"
                                       placeholder="User Name" />
                            </div>
                            <div class="form-group mb-3 col-md-6">
                                <label asp-for="FirstName" class="control-label"></label>
                                <input type="text"
                                       asp-for="FirstName"
                                       class="form-control"
                                       placeholder="First Name" />
                            </div>
                            <div class="form-group mb-3 col-md-6">
                                <label asp-for="LastName" class="control-label"></label>
                                <input type="text"
                                       asp-for="LastName"
                                       class="form-control"
                                       placeholder="First Name" />
                            </div>
                            <div class="form-group mb-3 col-md-6">
                                <label asp-for="Email" class="control-label"></label>
                                <input type="email"
                                       asp-for="Email"
                                       class="form-control"
                                       placeholder="Email" />
                            </div>

                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="EnteredPassword" class="control-label"></label>
                            <input type="password"
                                   asp-for="EnteredPassword"
                                   class="form-control"
                                   placeholder="Password" />
                        </div>

                        <button class="btn btn-info" asp-action="Register">
                            Signup
                        </button>
                    </form>
                    <p class="mt-3">
                        <a asp-action="Login">
                            Already Have an Account
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
